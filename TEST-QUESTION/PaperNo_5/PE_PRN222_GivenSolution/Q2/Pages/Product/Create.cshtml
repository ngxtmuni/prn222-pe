@page
@model Q2.Pages.Product.CreateModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Create Product</title>
</head>
<body>
    <h2>Create Product</h2>
    <form method="post">
        <div>
            <label>Product Name</label><br />
            <input type="text" asp-for="PNameSelected" />
        </div>
        <div>
            <label>Price</label><br />
            <input type="number" step="0.01" asp-for="PriceSelected" />
        </div>
        <div>
            <label>Quantity</label><br />
            <input type="number" asp-for="QuantitySelected" />
        </div>
        <div>
            <label>Status</label><br />
            <select asp-for="StatusSelected">
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </select>
        </div>
        <div>
            <label>Category</label><br />
            <select asp-for="CategoryIdSelected">
                @for (int i = 0; i < Model.Categories.Count; i++)
                {
                    var c = Model.Categories[i];
                    var isSelected = Model.CategoryIdSelected == c.CategoryId || (Model.CategoryIdSelected != 0 && i == 0);
                    if (isSelected)
                    {
                        <option value="@c.CategoryId" selected>@c.CategoryName</option>
                    }
                    else
                    {
                        <option value="@c.CategoryId">@c.CategoryName</option>
                    }
                }
            </select>
        </div>
        <div style="margin-top:12px;">
            <button type="submit">Save</button>
            <a href="">Back to List</a>
        </div>
    </form>
</body>
</html>

