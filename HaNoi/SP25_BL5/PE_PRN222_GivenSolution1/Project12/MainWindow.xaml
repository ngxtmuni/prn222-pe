<Window x:Class="Project12.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project12"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="txtStatus" Foreground="Red" FontSize="14" Visibility="Collapsed" Padding="10,5"></TextBlock>
                <Button Content="Reconnect" Width="100" Margin="0,5" Padding="10,0" Click="Button_Click"/>
            </StackPanel>
            <DataGrid x:Name="dgStudents" AutoGenerateColumns="True"/>
        </StackPanel>
    </Grid>
</Window>
