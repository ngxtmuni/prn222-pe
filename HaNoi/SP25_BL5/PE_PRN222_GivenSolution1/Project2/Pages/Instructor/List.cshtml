@page
@model Project2.Pages.Instructor.ListModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>
    <title>Page Title</title>
</head>

<body>

    <form method="get">
        Department

        <select id="sl_de" asp-for="DepartmentId">
            @for (int i = 0; i < Model.Departments.Count; i++)
            {
                var d = Model.Departments[i];
                var isSelected = Model.DepartmentId == d.DepartmentId || (!Model.DepartmentId.HasValue && i == 0);
                if (isSelected)
                {
                    <option id="op_@d.DepartmentId" value="@d.DepartmentId" selected>@d.DepartmentName</option>
                }
                else
                {
                    <option id="op_@d.DepartmentId" value="@d.DepartmentId">@d.DepartmentName</option>
                }
            }
        </select>

        Contract Type
        <select id="sl_contract" asp-for="ContractType">
            <option selected id="con_full" value="true">Fulltime</option>
            <option id="con_part" value="false">Parttime</option>
        </select>
        <br />
        Sort by:
        <input type="radio" checked id="rd_instructorName" asp-for="SortBy" value="InstructorName" /> InstructorName &nbsp;
        <input type="radio" id="rd_instructorId" asp-for="SortBy" value="InstructorId" /> InstructorId &nbsp;
        <input type="radio" id="rd_contractDate" asp-for="SortBy" value="ContractDate" /> ContractDate &nbsp;
        <br />
        <input type="submit" value="Filter" id="btn_submit" />
    </form>
    <h2>List of Instructors</h2>
    <table border="1">
        @for (int i = 0; i < Model.Instructors.Count(); i++)
        {
            var date = @Model.Instructors[i].ContractDate?.ToString("dd/MM/yyyy") ?? "";
            <tr>
                <td id="td_instructorId_@i">@Model.Instructors[i].InstructorId</td>
                <td id="td_fullName_@i">@Model.Instructors[i].Fullname</td>
                <td id="td_department_@i">@Model.Instructors[i].DepartmentNavigation?.DepartmentName</td>
                <td id="td_contractDate_@i">@date</td>
            </tr>
        }
    </table>
</body>
</html>


