<Window x:Class="Project12.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student Client" Height="400" Width="600">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock x:Name="txtStatus" Foreground="Red" Visibility="Collapsed" FontSize="14"/>
            <Button Content="Reconnect" Width="100" Margin="0,5" Click="Reconnect_Click"/>
            <DataGrid x:Name="dgStudents" AutoGenerateColumns="True"/>
        </StackPanel>
    </Grid>
</Window>